function build() {
    echo "$SEP"
    echo "BUILDING GCP SEED"
    echo "$SEP"
    install_tools
    setup_gcp
}

function test_app() {
    check_project

    if ! gcloud projects describe "$PROJECT_ID" &>/dev/null; then
        echo "❌ Project $PROJECT_ID does not exist. Run --build first."
        exit 1
    fi

    # FIX: Explicitly set account to ensure CLI context matches ADC for impersonation
    gcloud config set project "$PROJECT_ID" --quiet &>/dev/null
    gcloud config set account "$ACTIVE_ACCOUNT" --quiet &>/dev/null

    echo "Running connectivity test to GCS..."
    echo "Authentication method: $AUTH_METHOD"

    IMPERSONATE_FLAG=""

    if [[ "$AUTH_METHOD" == "keyfile" ]]; then
        if [ ! -f "$KEY_FILE" ]; then
            echo "❌ Key file not found at $KEY_FILE. Run --build first."
            exit 1
        fi
        export GOOGLE_APPLICATION_CREDENTIALS="$KEY_FILE"
        echo "Using key file: $KEY_FILE"
    else
        echo "Using service account impersonation: $SA_EMAIL"
        IMPERSONATE_FLAG="--impersonate-service-account=$SA_EMAIL"

        echo "Verifying impersonation permissions..."
        MAX_RETRIES=6
        RETRY_COUNT=0

        while [ $RETRY_COUNT -lt $MAX_RETRIES ]; do
            # FIX: Use print-access-token to verify the API and role are functional
            if gcloud auth print-access-token $IMPERSONATE_FLAG &>/dev/null; then
                echo "✅ Impersonation working."
                break
            else
                RETRY_COUNT=$((RETRY_COUNT + 1))
                if [ $RETRY_COUNT -lt $MAX_RETRIES ]; then
                    echo "⏳ Permission check failed. (attempt $RETRY_COUNT/$MAX_RETRIES)"
                    # FIX: Force-enable the API if it failed during the test
                    gcloud services enable iamcredentials.googleapis.com --project "$PROJECT_ID" --quiet &>/dev/null
                    sleep 10
                else
                    echo ""
                    echo "❌ Impersonation failed. This is likely a permission issue, not propagation."
                    echo "Run this to verify: gcloud iam service-accounts get-iam-policy $SA_EMAIL"
                    exit 1
                fi
            fi
        done
    fi

    echo "test-data-$(date)" > connection-test.tmp

    # Execute storage commands with explicit flag handling
    if [ -n "$IMPERSONATE_FLAG" ]; then
        gcloud storage cp connection-test.tmp "gs://$TF_STATE_BUCKET/test-connection.txt" $IMPERSONATE_FLAG
        gcloud storage rm "gs://$TF_STATE_BUCKET/test-connection.txt" $IMPERSONATE_FLAG
    else
        gcloud storage cp connection-test.tmp "gs://$TF_STATE_BUCKET/test-connection.txt"
        gcloud storage rm "gs://$TF_STATE_BUCKET/test-connection.txt"
    fi

    rm -f connection-test.tmp
    echo "✅ GCS Read/Write Verified."
}

function cleanup_bucket() {
    if gcloud storage buckets describe "gs://$TF_STATE_BUCKET" --project "$PROJECT_ID" &>/dev/null; then
        echo "Emptying GCS Bucket (all versions)..."
        gcloud storage rm --recursive "gs://$TF_STATE_BUCKET/**" 2>/dev/null || echo "Bucket already empty or inaccessible."
        echo "Deleting GCS Bucket..."
        gcloud storage buckets delete "gs://$TF_STATE_BUCKET" --project "$PROJECT_ID" 2>/dev/null || echo "Bucket already deleted."
        echo "✅ GCS Bucket deleted."
    else
        echo "✅ GCS Bucket $TF_STATE_BUCKET does not exist. Skipping."
    fi
}

function clean() {
    check_project

    if gcloud projects describe "$PROJECT_ID" &>/dev/null; then
        gcloud config set project "$PROJECT_ID" 2>/dev/null
        cleanup_bucket
    else
        echo "✅ Project $PROJECT_ID does not exist. Skipping bucket cleanup."
    fi

    #echo "Wiping local master key file..."
    #rm -rf "$KEY_DIR"
    #echo "✅ Local credentials removed."
}

function clean_all() {
    check_project

    #if ! gcloud projects describe "$PROJECT_ID" &>/dev/null; then
    #    echo "✅ Project $PROJECT_ID does not exist. Nothing to clean."
    #    rm -rf "$KEY_DIR"
    #    exit 0
    #fi

    gcloud config set project "$PROJECT_ID" 2>/dev/null

    echo "$SEP"
    echo "DANGER: Destructive Deletion of GCP Seed Resources"
    echo "Target Project: $PROJECT_ID"
    echo "$SEP"

    read -p "Type the Project ID ($PROJECT_ID) to confirm deletion: " CONFIRM_ID
    if [[ "$CONFIRM_ID" == "$PROJECT_ID" ]]; then

        # Idempotent Service Account Cleanup
        if gcloud iam service-accounts describe "$SA_EMAIL" --project "$PROJECT_ID" &>/dev/null; then
            echo "Cleaning up Service Account..."

            # Delete all keys
            KEYS=$(gcloud iam service-accounts keys list \
                --iam-account="$SA_EMAIL" \
                --project "$PROJECT_ID" \
                --filter="keyType=USER_MANAGED" \
                --format="value(name)" 2>/dev/null || echo "")

            if [[ -n "$KEYS" ]]; then
                echo "Deleting Service Account keys..."
                echo "$KEYS" | while read -r key_name; do
                    if [[ -n "$key_name" ]]; then
                        echo "Deleting key: $key_name"
                        gcloud iam service-accounts keys delete "$key_name" \
                            --iam-account="$SA_EMAIL" \
                            --project "$PROJECT_ID" \
                            --quiet 2>/dev/null || echo "Key already deleted."
                    fi
                done
            fi

            # Remove IAM bindings
            echo "Removing IAM policy bindings..."
            gcloud projects remove-iam-policy-binding "$PROJECT_ID" \
                --member="serviceAccount:$SA_EMAIL" \
                --role="roles/owner" \
                --quiet 2>/dev/null || echo "IAM binding already removed."

            # Delete the Service Account
            echo "Deleting Service Account: $SA_EMAIL..."
            gcloud iam service-accounts delete "$SA_EMAIL" \
                --project "$PROJECT_ID" \
                --quiet 2>/dev/null || echo "Service Account already deleted."
        else
            echo "✅ Service Account $SA_EMAIL does not exist. Skipping."
        fi

        # Delete Workload Identity Federation resources
        cleanup_workload_identity

        # Optional: Delete the entire project (commented out for safety)
        # Uncomment the following lines if you want to delete the entire project
        # echo "Deleting GCP Project: $PROJECT_ID..."
        # gcloud projects delete "$PROJECT_ID" --quiet

        if [[ "$AUTH_METHOD" == "keyfile" ]]; then
            _clear_sa_key_from_sops
        fi
        clean

        echo "✅ GCP Resources and local credentials wiped."
    else
        echo "Confirmation failed. Aborting."
        exit 1
    fi

    cat <<EOF
Note: The Project was not deleted.
Deleting and re-creating projects frequently in Google is not really supported.
The problem is that there is no way to truly purge a deleted project.
Projects persist in a recoverable state for 30 days, and can not be purged.
They count toward the account quota for projects (which defaults to 5...).
So, don't delete projects until/unless absolutely necessary.
Instead, re-use them.
To see your quota:
  gcloud beta quotas info list --service=cloudresourcemanager.googleapis.com --organization=<ORG_ID> | yq '.dimensionsInfos[].details.value'
  # gcloud projects list # list projects
EOF
}

function show_status() {
    echo "$SEP"
    echo "GCP SEED PROJECT STATUS"
    echo "$SEP"

    # Basic Configuration
    echo "Configuration:"
    echo "  Project ID:     $PROJECT_ID"
    echo "  Region:         $REGION"
    echo "  Organization:   ${GCP_ORG_ID:-"None (personal account)"}"
    echo "  Environment:    $ENV_TAG_VALUE"
    echo "  Auth Method:    $AUTH_METHOD"
    echo ""

    # Authentication Details
    echo "Authentication:"
    if [[ "$AUTH_METHOD" == "keyfile" ]]; then
        echo "  Key File:       $KEY_FILE"
        if [ -f "$KEY_FILE" ]; then
            echo "  Key Status:     ✅ Present"
        else
            echo "  Key Status:     ❌ Missing"
        fi
        echo ""
        echo "  Usage:"
        echo "    export GOOGLE_APPLICATION_CREDENTIALS=\"$KEY_FILE\""
    else
        echo "  SA Email:       $SA_EMAIL"
        echo ""
        echo "  Usage:"
        echo "    export GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=\"$SA_EMAIL\""
        echo ""
        echo "  Or in Terraform/OpenTofu:"
        echo "    provider \"google\" {"
        echo "      impersonate_service_account = \"$SA_EMAIL\""
        echo "    }"
    fi
    echo ""

    # Resource Status
    if command -v gcloud &>/dev/null; then
        echo "$SEP"
        echo "RESOURCE STATUS"
        echo "$SEP"

        # Project Status
        echo "📦 Project:"
        if gcloud projects describe "$PROJECT_ID" &>/dev/null; then
            PROJECT_NUMBER=$(gcloud projects describe "$PROJECT_ID" --format="value(projectNumber)" 2>/dev/null)
            PROJECT_STATE=$(gcloud projects describe "$PROJECT_ID" --format="value(lifecycleState)" 2>/dev/null)
            echo "  Status:         ✅ $PROJECT_STATE"
            echo "  Project Number: $PROJECT_NUMBER"
            echo "  Console:        https://console.cloud.google.com/home/dashboard?project=$PROJECT_ID"
        else
            echo "  Status:         ❌ Not found"
        fi
        echo ""

        # Billing Status
        echo "💳 Billing:"
        BILLING_STATUS=$(gcloud billing projects describe "$PROJECT_ID" --format="value(billingEnabled)" 2>/dev/null || echo "false")
        BILLING_ACCOUNT=$(gcloud billing projects describe "$PROJECT_ID" --format="value(billingAccountName)" 2>/dev/null || echo "None")
        if [[ "$BILLING_STATUS" == "True" ]]; then
            echo "  Status:         ✅ Enabled"
            echo "  Account:        $BILLING_ACCOUNT"
        else
            echo "  Status:         ❌ Disabled"
        fi
        echo ""

        # Tags Status (if in organization)
        if [[ -n "$GCP_ORG_ID" ]]; then
            echo "🏷️  Project Tags:"
            PROJECT_TAGS=$(gcloud resource-manager tags bindings list \
                --parent="//cloudresourcemanager.googleapis.com/projects/$PROJECT_ID" \
                --format="value(tagValue)" 2>/dev/null || echo "")

            if [[ -n "$PROJECT_TAGS" ]]; then
                echo "  Status:         ✅ Tags applied"
                while IFS= read -r tag; do
                    # Extract tag key and value from the full path
                    TAG_KEY=$(echo "$tag" | grep -oP 'tagKeys/\K[^/]+' || echo "unknown")
                    TAG_VAL=$(echo "$tag" | grep -oP 'tagValues/\K[^/]+' || echo "unknown")
                    echo "  Tag:            $TAG_KEY = $TAG_VAL"
                done <<< "$PROJECT_TAGS"
            else
                echo "  Status:         ⚠️  No tags applied"
                echo "  Note:           Tags are optional but useful for organization"
            fi
            echo ""
        fi

        # Service Account Status
        echo "🔐 Service Account:"
        if gcloud iam service-accounts describe "$SA_EMAIL" --project "$PROJECT_ID" &>/dev/null; then
            echo "  Status:         ✅ Active"
            echo "  Email:          $SA_EMAIL"

            # Check IAM roles
            echo "  Roles:"
            SA_ROLES=$(gcloud projects get-iam-policy "$PROJECT_ID" \
                --flatten="bindings[].members" \
                --filter="bindings.members:serviceAccount:$SA_EMAIL" \
                --format="value(bindings.role)" 2>/dev/null | sort -u)

            if [[ -n "$SA_ROLES" ]]; then
                while IFS= read -r role; do
                    echo "    - $role"
                done <<< "$SA_ROLES"
            else
                echo "    - ❌ No roles found"
            fi

            # Check keys if using keyfile method
            if [[ "$AUTH_METHOD" == "keyfile" ]]; then
                KEY_COUNT=$(gcloud iam service-accounts keys list \
                    --iam-account="$SA_EMAIL" \
                    --project "$PROJECT_ID" \
                    --filter="keyType=USER_MANAGED" \
                    --format="value(name)" 2>/dev/null | wc -l)
                echo "  Keys:           $KEY_COUNT user-managed key(s)"
            fi
        else
            echo "  Status:         ❌ Not found"
        fi
        echo ""

        # GCS Bucket Status
        echo "🪣 GCS State Bucket:"
        if gcloud storage buckets describe "gs://$TF_STATE_BUCKET" --project "$PROJECT_ID" &>/dev/null; then
            echo "  Status:         ✅ Active"
            echo "  Name:           gs://$TF_STATE_BUCKET"

            BUCKET_LOCATION=$(gcloud storage buckets describe "gs://$TF_STATE_BUCKET" \
                --project "$PROJECT_ID" \
                --format="value(location)" 2>/dev/null)
            echo "  Location:       $BUCKET_LOCATION"

            VERSIONING=$(gcloud storage buckets describe "gs://$TF_STATE_BUCKET" \
                --project "$PROJECT_ID" \
                --format="value(versioning.enabled)" 2>/dev/null)
            if [[ "$VERSIONING" == "True" ]]; then
                echo "  Versioning:     ✅ Enabled"
            else
                echo "  Versioning:     ❌ Disabled"
            fi

            UBLA=$(gcloud storage buckets describe "gs://$TF_STATE_BUCKET" \
                --project "$PROJECT_ID" \
                --format="value(iamConfiguration.uniformBucketLevelAccess.enabled)" 2>/dev/null)
            if [[ "$UBLA" == "True" ]]; then
                echo "  Access:         ✅ Uniform bucket-level access"
            else
                echo "  Access:         ⚠️  Fine-grained ACLs"
            fi

            # Object count
            OBJECT_COUNT=$(gcloud storage ls "gs://$TF_STATE_BUCKET/**" 2>/dev/null | wc -l || echo "0")
            echo "  Objects:        $OBJECT_COUNT file(s)"
            echo "  Console:        https://console.cloud.google.com/storage/browser/$TF_STATE_BUCKET?project=$PROJECT_ID"
        else
            echo "  Status:         ❌ Not found"
        fi
        echo ""

        # Enabled APIs
        echo "🔌 Enabled APIs:"
        ENABLED_APIS=$(gcloud services list --enabled --project "$PROJECT_ID" --format="value(config.name)" 2>/dev/null | grep -E "(compute|storage|iam|cloudresourcemanager)" | head -5)
        if [[ -n "$ENABLED_APIS" ]]; then
            while IFS= read -r api; do
                echo "  - $api"
            done <<< "$ENABLED_APIS"
            API_COUNT=$(gcloud services list --enabled --project "$PROJECT_ID" --format="value(config.name)" 2>/dev/null | wc -l)
            echo "  ... and $((API_COUNT - 5)) more"
        else
            echo "  - None found"
        fi
    else
        echo "❌ gcloud CLI not available. Install with --build"
    fi

    echo ""
    echo "$SEP"
    echo "Next Steps:"
    echo "$SEP"
    echo "1. Verify connectivity: ./run --test"
    echo "2. Configure Terragrunt backend with:"
    echo "   Bucket: $TF_STATE_BUCKET"
    echo "   Project: $PROJECT_ID"
    if [[ "$AUTH_METHOD" == "impersonation" ]]; then
        echo "3. Set environment variable:"
        echo "   export GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=\"$SA_EMAIL\""
    else
        echo "3. Set environment variable:"
        echo "   export GOOGLE_APPLICATION_CREDENTIALS=\"$KEY_FILE\""
    fi
    echo ""
}

function show_usage() {
    printf "Usage: $0 <command>\n"
    cat <<EOF
    --seed|-b       Install tools and provision GCP seed resources
    --login|-l      Verify GCP authentication
    --test|-t       Verify GCS bucket access
    --status|-S     Show GCP resource status
    --clean         Remove GCS bucket
    --clean-all     DELETE bucket, service account, and WIF resources
    --help|-h       Show this help
EOF
    exit 1
}

################################################################################
# MAIN
################################################################################

case "${1:-}" in
    --seed|-b)    _load_seed_config; build ;;
    --login|-l)   _load_seed_config; check_project ;;
    --test|-t)    _load_seed_config; test_app ;;
    --status|-S)  _load_seed_config; show_status ;;
    --clean)      _load_seed_config; clean ;;
    --clean-all)  _load_seed_config; clean_all ;;
    --help|-h)    show_usage ;;
    *) echo "Usage: $0 <--seed|--login|--test|--status|--clean|--clean-all>" >&2; exit 1 ;;
esac
